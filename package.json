{
  "name": "ventureos",
  "version": "0.1.0",
  "description": "Mission Control for AI Agent Teams — real-time dashboard for observing AI agent collaboration",
  "keywords": ["ai-agents", "dashboard", "real-time", "mcp", "event-sourcing", "websocket", "react", "bun"],
  "homepage": "https://github.com/aviraldua93/ventureos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aviraldua93/ventureos.git"
  },
  "bugs": {
    "url": "https://github.com/aviraldua93/ventureos/issues"
  },
  "license": "MIT",
  "author": "aviraldua93",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "postinstall": "node scripts/fix-bun-types.js",
    "dev": "bun run --filter '@ventureos/server' dev & bun run --filter '@ventureos/dashboard' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "type-check": "bun run --filter '*' type-check",
    "test:e2e": "cd packages/dashboard && bunx playwright test --config e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/pino": "^7.0.5",
    "picomatch": "^4.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0"
  }
}
